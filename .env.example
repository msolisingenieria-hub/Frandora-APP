# ──────────────────────────────────────────────────────────
# FRANDORA — Variables de Entorno
# Copia este archivo como .env.local y completa los valores
# NUNCA subas .env.local a git
# ──────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.frandora.cl
NEXT_PUBLIC_ROOT_DOMAIN=frandora.cl
NODE_ENV=development

# ── Base de Datos (Supabase) ──────────────────────────────
# Obtener en: supabase.com → tu proyecto → Settings → Database
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Autenticación (Clerk) ─────────────────────────────────
# Obtener en: clerk.com → tu app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# URLs de Clerk (no cambiar)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── Pagos — Suscripciones Frandora (Rebill) ──────────────
# Rebill: especializado en SaaS/suscripciones para Latam
# Obtener en: rebill.com → Dashboard → API Keys
# Documentación: https://docs.rebill.com
REBILL_API_KEY=...
REBILL_ORGANIZATION_ID=...
REBILL_WEBHOOK_SECRET=...
REBILL_ENVIRONMENT=sandbox

# ── Pagos — Cobros a Clientes de Negocios (Flow.cl) ──────
# Flow: pasarela de pagos chilena para cobros en reservas
# Obtener en: app.flow.cl → Configuración → API Keys
# Documentación: https://developers.flow.cl
FLOW_API_KEY=...
FLOW_SECRET_KEY=...
FLOW_ENVIRONMENT=sandbox
# sandbox: https://sandbox.flow.cl/api | produccion: https://www.flow.cl/api
FLOW_API_URL=https://sandbox.flow.cl/api

# ── Email (Resend) ────────────────────────────────────────
# Obtener en: resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@frandora.cl
RESEND_FROM_NAME=Frandora

# ── SMS y WhatsApp (Twilio) ───────────────────────────────
# Obtener en: twilio.com → Console → Account Info
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
TWILIO_WHATSAPP_NUMBER=whatsapp:+1...

# ── Cache y Colas (Upstash Redis) ────────────────────────
# Obtener en: upstash.com → Redis → tu database → REST API
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── Storage de Archivos (Cloudflare R2) ──────────────────
# Alternativa: usar Supabase Storage (comentar estas y configurar supabase)
CLOUDFLARE_R2_ACCOUNT_ID=...
CLOUDFLARE_R2_ACCESS_KEY_ID=...
CLOUDFLARE_R2_SECRET_ACCESS_KEY=...
CLOUDFLARE_R2_BUCKET_NAME=frandora-uploads
CLOUDFLARE_R2_PUBLIC_URL=https://...r2.dev

# ── Google APIs ───────────────────────────────────────────
# Obtener en: console.cloud.google.com
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_MAPS_API_KEY=...

# ── Monitoreo (Sentry) ────────────────────────────────────
# Obtener en: sentry.io → tu proyecto → Settings → SDK Setup
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=...
SENTRY_ORG=frandora
SENTRY_PROJECT=frandora-app

# ── Analytics (PostHog) ───────────────────────────────────
# Obtener en: app.posthog.com → Project Settings
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Soporte (Crisp) ───────────────────────────────────────
NEXT_PUBLIC_CRISP_WEBSITE_ID=...
