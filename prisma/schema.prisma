// Frandora — Schema de Base de Datos Completo
// Proveedor: PostgreSQL via Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  BUSINESS_OWNER
  MANAGER
  STAFF
  RECEPTIONIST
  CLIENT
}

enum PlanTier {
  STARTER
  PROFESSIONAL
  BUSINESS
  SCALE
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  QR
  ONLINE
  GIFT_CARD
  MIXED
}

enum NotificationType {
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

enum NotificationEvent {
  APPOINTMENT_CREATED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_REMINDER_24H
  APPOINTMENT_REMINDER_1H
  APPOINTMENT_CANCELED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_COMPLETED
  PAYMENT_RECEIVED
  INVOICE_SENT
  BIRTHDAY
  REBOOKING_REMINDER
  REVIEW_REQUEST
  WELCOME
  PLAN_EXPIRING
}

enum GiftCardStatus {
  ACTIVE
  USED
  EXPIRED
  CANCELED
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
  PURCHASE
  SALE
  RETURN
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELED
}

enum CampaignChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum FormFieldType {
  TEXT
  TEXTAREA
  SELECT
  CHECKBOX
  DATE
  PHONE
  EMAIL
  SIGNATURE
}

enum CouponType {
  FIXED_AMOUNT
  PERCENTAGE
}

enum BusinessCategory {
  BARBERSHOP
  HAIR_SALON
  BEAUTY_SALON
  SPA
  NAIL_SALON
  TATTOO
  FITNESS_GYM
  YOGA_PILATES
  MASSAGE
  AESTHETIC_CLINIC
  DENTAL
  PHYSIOTHERAPY
  PSYCHOLOGY
  NUTRITION
  VETERINARY
  COACHING
  OTHER
}

// ─────────────────────────────────────────────
// USUARIOS
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String
  phone     String?
  avatarUrl String?
  role      UserRole @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedBusinesses  Business[]        @relation("BusinessOwner")
  staffMemberships StaffMember[]
  appointments     Appointment[]     @relation("ClientAppointments")
  notifications    Notification[]

  @@index([email])
  @@index([clerkId])
}

// ─────────────────────────────────────────────
// NEGOCIO
// ─────────────────────────────────────────────

model Business {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String
  description String?
  category    BusinessCategory
  logoUrl     String?
  bannerUrl   String?
  email       String?
  phone       String?
  website     String?
  customDomain String?

  ownerId String
  owner   User   @relation("BusinessOwner", fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations      BusinessLocation[]
  staff          StaffMember[]
  services       Service[]
  serviceCategories ServiceCategory[]
  clients        Client[]
  appointments   Appointment[]
  products       Product[]
  productCategories ProductCategory[]
  giftCards      GiftCard[]
  coupons        Coupon[]
  campaigns      Campaign[]
  forms          Form[]
  reviews        Review[]
  groupClasses   GroupClass[]
  waitlist       Waitlist[]
  timeBlocks     TimeBlock[]
  settings       BusinessSettings?
  customization  BusinessCustomization?
  subscription   Subscription?
  notifications  Notification[]

  @@index([slug])
  @@index([ownerId])
}

model BusinessLocation {
  id         String  @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name       String
  address    String
  city       String
  state      String?
  country    String  @default("CL")
  postalCode String?
  lat        Float?
  lng        Float?
  phone      String?
  isMain     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff        StaffMember[]
  appointments Appointment[]
  schedules    LocationSchedule[]

  @@index([businessId])
}

model LocationSchedule {
  id         String           @id @default(cuid())
  locationId String
  location   BusinessLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  dayOfWeek  Int
  openTime   String
  closeTime  String
  isClosed   Boolean @default(false)

  @@index([locationId])
}

model BusinessSettings {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  currency           String  @default("CLP")
  timezone           String  @default("America/Santiago")
  locale             String  @default("es-CL")
  bookingAdvanceDays Int     @default(60)
  minCancelHours     Int     @default(24)
  bufferMinutes      Int     @default(0)
  noShowFee          Float?
  depositPercent     Int     @default(0)
  requirePayment     Boolean @default(false)
  autoConfirm        Boolean @default(true)
  allowClientCancel  Boolean @default(true)
  allowClientReschedule Boolean @default(true)
  taxPercent         Float   @default(0)
  taxName            String  @default("IVA")

  smsEnabled         Boolean @default(false)
  whatsappEnabled    Boolean @default(false)
  emailEnabled       Boolean @default(true)
  reminder24h        Boolean @default(true)
  reminder1h         Boolean @default(false)
  reviewRequestEnabled Boolean @default(true)
  rebookingReminderDays Int   @default(30)

  loyaltyEnabled          Boolean @default(false)
  loyaltyPointsPerBooking Int     @default(10)
  loyaltyPointsPerPurchase Int    @default(1)
  loyaltyPointValue       Int     @default(100)

  socialInstagram String?
  socialFacebook  String?
  socialTiktok    String?
  socialWhatsapp  String?

  updatedAt DateTime @updatedAt
}

model BusinessCustomization {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  primaryColor   String @default("#6d28d9")
  secondaryColor String @default("#a78bfa")
  accentColor    String @default("#f59e0b")
  fontFamily     String @default("Inter")
  borderRadius   String @default("0.75rem")
  darkMode       Boolean @default(false)

  heroTitle       String?
  heroSubtitle    String?
  heroImageUrl    String?
  heroVideoUrl    String?
  galleryUrls     String[]
  metaTitle       String?
  metaDescription String?

  // Página pública premium (Fase 12)
  servicesLayout     String  @default("grid")   // "grid" | "list"
  showGallery        Boolean @default(true)
  showMap            Boolean @default(true)
  showSchedule       Boolean @default(true)
  showStaffBios      Boolean @default(true)
  showReviews        Boolean @default(true)
  showFaq            Boolean @default(true)
  cancellationPolicy String?
  faqs               Json    @default("[]")     // [{ question, answer }][]
  mapEmbed           String?                    // Google Maps embed URL
  customDomain       String?                    // dominio propio (Business+)

  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// STAFF Y HORARIOS
// ─────────────────────────────────────────────

model StaffMember {
  id         String  @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?   @relation(fields: [userId], references: [id])
  locationId String?
  location   BusinessLocation? @relation(fields: [locationId], references: [id])

  name        String
  email       String?
  phone       String?
  avatarUrl   String?
  bio         String?
  specialties String[] @default([])
  role        UserRole @default(STAFF)
  color       String   @default("#6d28d9")
  isActive    Boolean  @default(true)
  commissionRate Float? @default(0)
  commissionType String @default("PERCENT")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedules    StaffSchedule[]
  timeOff      StaffTimeOff[]
  services     StaffService[]
  appointments Appointment[]
  groupClasses GroupClass[]
  timeBlocks   TimeBlock[]

  @@index([businessId])
  @@index([userId])
}

model StaffSchedule {
  id          String      @id @default(cuid())
  staffId     String
  staff       StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  dayOfWeek   Int
  startTime   String
  endTime     String
  isAvailable Boolean @default(true)

  @@index([staffId])
}

model StaffTimeOff {
  id      String      @id @default(cuid())
  staffId String
  staff   StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  startDate DateTime
  endDate   DateTime
  reason    String?

  @@index([staffId])
}

model StaffService {
  staffId   String
  staff     StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  price     Float?

  @@id([staffId, serviceId])
}

// ─────────────────────────────────────────────
// SERVICIOS
// ─────────────────────────────────────────────

model ServiceCategory {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name     String
  color    String  @default("#6d28d9")
  order    Int     @default(0)
  isActive Boolean @default(true)

  services Service[]

  @@index([businessId])
}

model Service {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  categoryId String?
  category   ServiceCategory? @relation(fields: [categoryId], references: [id])

  name        String
  description String?
  imageUrl    String?
  duration    Int
  price       Float
  priceMax    Float?
  isOnline    Boolean @default(true)
  isActive    Boolean @default(true)
  order       Int     @default(0)
  color       String  @default("#6d28d9")
  requiresDeposit Boolean @default(false)
  depositAmount   Float?
  bufferMinutes   Int     @default(0)
  prepTime        Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff            StaffService[]
  appointmentItems AppointmentService[]
  addOns           ServiceAddOn[]
  groupClasses     GroupClass[]

  @@index([businessId])
  @@index([categoryId])
}

model ServiceAddOn {
  id        String  @id @default(cuid())
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  name     String
  price    Float
  duration Int     @default(0)
  isActive Boolean @default(true)

  @@index([serviceId])
}

// ─────────────────────────────────────────────
// CLIENTES DEL NEGOCIO
// ─────────────────────────────────────────────

model Client {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name      String
  email     String?
  phone     String?
  avatarUrl String?
  birthdate DateTime?
  gender    String?
  notes     String?
  tags      String[]
  isActive  Boolean   @default(true)

  allergies     String?
  preferences   String?
  referredBy    String?
  source        String?
  loyaltyPoints Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments AppointmentClient[]
  payments     Payment[]
  giftCards    GiftCard[]   @relation("GiftCardRecipient")
  formResponses FormResponse[]
  classEnrollments ClassEnrollment[]

  @@unique([businessId, email])
  @@index([businessId])
  @@index([phone])
}

// ─────────────────────────────────────────────
// CITAS / RESERVAS
// ─────────────────────────────────────────────

model Appointment {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  locationId String?
  location   BusinessLocation? @relation(fields: [locationId], references: [id])
  staffId    String?
  staff      StaffMember? @relation(fields: [staffId], references: [id])
  userId     String?
  user       User?    @relation("ClientAppointments", fields: [userId], references: [id])

  bookingCode String @unique @default(cuid())
  status      AppointmentStatus @default(PENDING)
  startTime   DateTime
  endTime     DateTime
  totalPrice  Float
  notes       String?
  internalNotes String?
  source      String  @default("ONLINE")
  confirmationSentAt DateTime?
  reminderSentAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients  AppointmentClient[]
  services AppointmentService[]
  payment  Payment?
  formResponses FormResponse[]
  review   Review?

  @@index([businessId])
  @@index([staffId])
  @@index([startTime])
  @@index([status])
}

model AppointmentClient {
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@id([appointmentId, clientId])
}

model AppointmentService {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id])

  serviceName   String
  price         Float
  duration      Int

  @@index([appointmentId])
}

// ─────────────────────────────────────────────
// PAGOS Y FACTURAS
// ─────────────────────────────────────────────

model Payment {
  id            String   @id @default(cuid())
  businessId    String
  appointmentId String?  @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id])

  amount          Float
  tip             Float  @default(0)
  discount        Float  @default(0)
  taxAmount       Float  @default(0)
  total           Float
  currency        String @default("CLP")
  method          PaymentMethod @default(CASH)
  status          PaymentStatus @default(PENDING)
  flowOrderId     String?
  flowToken       String?
  giftCardId      String?
  notes           String?
  refundedAmount  Float?
  refundReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice Invoice?

  @@index([businessId])
  @@index([clientId])
}

model Invoice {
  id        String  @id @default(cuid())
  paymentId String  @unique
  payment   Payment @relation(fields: [paymentId], references: [id])

  invoiceNumber String @unique
  issueDate     DateTime @default(now())
  dueDate       DateTime?
  pdfUrl        String?
  emailSentAt   DateTime?
  notes         String?

  @@index([paymentId])
}

// ─────────────────────────────────────────────
// INVENTARIO Y PRODUCTOS
// ─────────────────────────────────────────────

model ProductCategory {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name     String
  order    Int     @default(0)
  isActive Boolean @default(true)

  products Product[]

  @@index([businessId])
}

model Product {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id])

  name        String
  description String?
  sku         String?
  barcode     String?
  imageUrl    String?
  costPrice   Float   @default(0)
  salePrice   Float
  stock       Int     @default(0)
  minStock    Int     @default(5)
  unit        String  @default("un")
  isActive    Boolean @default(true)
  isSellable  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements InventoryMovement[]

  @@index([businessId])
  @@index([sku])
}

model InventoryMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  type      InventoryMovementType
  quantity  Int
  unitCost  Float?
  reference String?
  notes     String?
  createdAt DateTime @default(now())

  @@index([productId])
}

// ─────────────────────────────────────────────
// GIFT CARDS
// ─────────────────────────────────────────────

model GiftCard {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  recipientId String?
  recipient   Client?  @relation("GiftCardRecipient", fields: [recipientId], references: [id])

  code          String @unique
  initialValue  Float
  currentValue  Float
  status        GiftCardStatus @default(ACTIVE)
  expiresAt     DateTime?
  purchaserName String?
  purchaserEmail String?
  message       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([code])
}

model Coupon {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  code        String
  description String?
  type        CouponType
  value       Float
  minAmount   Float?
  maxUses     Int?
  usedCount   Int      @default(0)
  isActive    Boolean  @default(true)
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, code])
  @@index([businessId])
}

// ─────────────────────────────────────────────
// MARKETING Y COMUNICACIONES
// ─────────────────────────────────────────────

model Campaign {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  subject     String?
  content     String
  channel     CampaignChannel
  status      CampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  sentCount   Int @default(0)
  openCount   Int @default(0)
  clickCount  Int @default(0)
  segment     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

model Notification {
  id         String   @id @default(cuid())
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])

  type    NotificationType
  event   NotificationEvent
  to      String
  subject String?
  body    String
  status  String  @default("SENT")
  error   String?

  sentAt    DateTime @default(now())

  @@index([businessId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// FORMULARIOS
// ─────────────────────────────────────────────

model Form {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  description String?
  isRequired  Boolean @default(false)
  isActive    Boolean @default(true)
  sendBefore  Int     @default(24)

  fields    FormField[]
  responses FormResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

model FormField {
  id     String @id @default(cuid())
  formId String
  form   Form   @relation(fields: [formId], references: [id], onDelete: Cascade)

  label       String
  type        FormFieldType
  placeholder String?
  options     String[]
  isRequired  Boolean @default(false)
  order       Int     @default(0)

  @@index([formId])
}

model FormResponse {
  id            String      @id @default(cuid())
  formId        String
  form          Form        @relation(fields: [formId], references: [id])
  clientId      String?
  client        Client?     @relation(fields: [clientId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  data      Json
  signedAt  DateTime?
  signature String?

  createdAt DateTime @default(now())

  @@index([formId])
  @@index([clientId])
}

// ─────────────────────────────────────────────
// RESEÑAS
// ─────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  appointmentId String?     @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  clientName  String
  clientEmail String?
  rating      Int
  comment     String?
  isVerified  Boolean @default(false)
  isPublic    Boolean @default(true)
  reply       String?
  repliedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([businessId])
}

// ─────────────────────────────────────────────
// AGENDA AVANZADA — Fase 8
// ─────────────────────────────────────────────

model GroupClass {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffId    String?
  staff      StaffMember? @relation(fields: [staffId], references: [id])
  serviceId  String?
  service    Service?  @relation(fields: [serviceId], references: [id])

  name        String
  description String?
  color       String  @default("#6FA89E")
  maxCapacity Int
  price       Float   @default(0)
  requiresDeposit Boolean @default(false)
  depositAmount   Float?

  startTime DateTime
  endTime   DateTime
  isRecurring Boolean @default(false)
  recurringRule String? // JSON: { frequency: "WEEKLY", days: [1,3,5] }

  isActive  Boolean @default(true)
  isPublic  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments ClassEnrollment[]

  @@index([businessId])
  @@index([startTime])
}

model ClassEnrollment {
  id         String     @id @default(cuid())
  classId    String
  class      GroupClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  clientId   String?
  client     Client?    @relation(fields: [clientId], references: [id])

  clientName  String
  clientEmail String?
  clientPhone String?
  status      EnrollmentStatus @default(ENROLLED)
  checkedInAt DateTime?
  paymentId   String?

  createdAt DateTime @default(now())

  @@index([classId])
}

model Waitlist {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceId  String?
  staffId    String?
  classId    String?

  clientName  String
  clientEmail String?
  clientPhone String?
  preferredDate DateTime?
  notes       String?
  status      WaitlistStatus @default(WAITING)
  notifiedAt  DateTime?

  createdAt DateTime @default(now())

  @@index([businessId])
}

model TimeBlock {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffId    String?
  staff      StaffMember? @relation(fields: [staffId], references: [id])

  title     String
  startTime DateTime
  endTime   DateTime
  color     String  @default("#94a3b8")
  reason    String? // vacaciones, reunión, descanso, limpieza, etc.

  createdAt DateTime @default(now())

  @@index([businessId])
  @@index([startTime])
}

enum EnrollmentStatus {
  ENROLLED
  WAITLISTED
  CANCELED
  ATTENDED
  NO_SHOW
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  CONFIRMED
  EXPIRED
}

// ─────────────────────────────────────────────
// SUSCRIPCIONES A FRANDORA (Planes)
// ─────────────────────────────────────────────

model Plan {
  id   String   @id @default(cuid())
  tier PlanTier @unique

  name            String
  description     String?
  monthlyPrice    Float
  annualPrice     Float
  staffLimit      Int?
  locationLimit   Int?
  appointmentLimit Int?
  smsIncluded     Int     @default(0)
  features        String[]
  rebillMonthlyPriceId String?
  rebillAnnualPriceId  String?
  isActive        Boolean @default(true)

  subscriptions Subscription[]
}

model Subscription {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  planId     String
  plan       Plan     @relation(fields: [planId], references: [id])

  status            SubscriptionStatus @default(TRIALING)
  rebillCustomerId  String?
  rebillSubId       String?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  cancelAtPeriodEnd  Boolean @default(false)
  isAnnual           Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([rebillSubId])
}

// ─────────────────────────────────────────────
// AUDIT LOG — Fase 11
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  businessId String?
  userId     String?

  action     String   // CREATE_APPOINTMENT, CANCEL_APPOINTMENT, UPDATE_SETTINGS, etc.
  resource   String   // appointment, client, payment, staff, settings
  resourceId String?
  metadata   Json?    // datos adicionales del evento
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([businessId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
