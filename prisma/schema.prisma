// Frandora — Schema de Base de Datos Completo
// Proveedor: PostgreSQL via Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  BUSINESS_OWNER
  MANAGER
  STAFF
  RECEPTIONIST
  CLIENT
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
  CANCELED
}

enum PlanTier {
  STARTER
  PROFESSIONAL
  BUSINESS
  SCALE
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  QR
  ONLINE
  GIFT_CARD
  MIXED
}

enum NotificationType {
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

enum NotificationEvent {
  APPOINTMENT_CREATED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_REMINDER_24H
  APPOINTMENT_REMINDER_1H
  APPOINTMENT_CANCELED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_COMPLETED
  PAYMENT_RECEIVED
  INVOICE_SENT
  BIRTHDAY
  REBOOKING_REMINDER
  REVIEW_REQUEST
  WELCOME
  PLAN_EXPIRING
}

enum GiftCardStatus {
  ACTIVE
  USED
  EXPIRED
  CANCELED
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
  PURCHASE
  SALE
  RETURN
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELED
}

enum CampaignChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum FormFieldType {
  TEXT
  TEXTAREA
  NUMBER
  SELECT
  CHECKBOX
  BOOLEAN
  DATE
  PHONE
  EMAIL
  SIGNATURE
  SCALE
}

enum FormType {
  PRE_APPOINTMENT
  POST_APPOINTMENT
  INTAKE
  CONSENT
}

enum CouponType {
  FIXED_AMOUNT
  PERCENTAGE
}

enum BusinessCategory {
  BARBERSHOP
  HAIR_SALON
  BEAUTY_SALON
  SPA
  NAIL_SALON
  TATTOO
  FITNESS_GYM
  YOGA_PILATES
  MASSAGE
  AESTHETIC_CLINIC
  DENTAL
  PHYSIOTHERAPY
  PSYCHOLOGY
  NUTRITION
  VETERINARY
  COACHING
  OTHER
}

// ─────────────────────────────────────────────
// USUARIOS
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String
  phone     String?
  avatarUrl String?
  role      UserRole @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedBusinesses  Business[]        @relation("BusinessOwner")
  staffMemberships StaffMember[]
  appointments     Appointment[]     @relation("ClientAppointments")
  notifications    Notification[]

  @@index([email])
  @@index([clerkId])
}

// ─────────────────────────────────────────────
// NEGOCIO
// ─────────────────────────────────────────────

model Business {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String
  description String?
  category    BusinessCategory
  logoUrl     String?
  bannerUrl   String?
  email       String?
  phone       String?
  website     String?
  customDomain String?

  status  BusinessStatus @default(ACTIVE)

  ownerId String
  owner   User   @relation("BusinessOwner", fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminNotes     BusinessNote[]
  featureFlags   BusinessFeatureFlag[]
  supportTickets SupportTicket[]
  locations      BusinessLocation[]
  staff          StaffMember[]
  services       Service[]
  serviceCategories ServiceCategory[]
  clients        Client[]
  appointments   Appointment[]
  products       Product[]
  productCategories ProductCategory[]
  giftCards      GiftCard[]
  coupons        Coupon[]
  campaigns      Campaign[]
  forms          Form[]
  reviews        Review[]
  soapNotes      SoapNote[]
  soapTemplates  SoapTemplate[]
  beforeAfterPhotos BeforeAfterPhoto[]
  groupClasses   GroupClass[]
  waitlist       Waitlist[]
  timeBlocks     TimeBlock[]
  settings       BusinessSettings?
  customization  BusinessCustomization?
  subscription   Subscription?
  notifications  Notification[]
  memberships    Membership[]
  clientMemberships ClientMembership[]
  sessionPackages SessionPackage[]
  clientPackages  ClientPackage[]
  clientPortalTokens ClientPortalToken[]

  @@index([slug])
  @@index([ownerId])
}

model BusinessLocation {
  id         String  @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name       String
  address    String
  city       String
  state      String?
  country    String  @default("CL")
  postalCode String?
  lat        Float?
  lng        Float?
  phone      String?
  isMain     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff        StaffMember[]
  appointments Appointment[]
  schedules    LocationSchedule[]

  @@index([businessId])
}

model LocationSchedule {
  id         String           @id @default(cuid())
  locationId String
  location   BusinessLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  dayOfWeek  Int
  openTime   String
  closeTime  String
  isClosed   Boolean @default(false)

  @@index([locationId])
}

model BusinessSettings {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  currency           String  @default("CLP")
  timezone           String  @default("America/Santiago")
  locale             String  @default("es-CL")
  bookingAdvanceDays Int     @default(60)
  minCancelHours     Int     @default(24)
  bufferMinutes      Int     @default(0)
  noShowFee          Float?
  depositPercent     Int     @default(0)
  requirePayment     Boolean @default(false)
  autoConfirm        Boolean @default(true)
  allowClientCancel  Boolean @default(true)
  allowClientReschedule Boolean @default(true)
  taxPercent         Float   @default(0)
  taxName            String  @default("IVA")

  smsEnabled         Boolean @default(false)
  whatsappEnabled    Boolean @default(false)
  emailEnabled       Boolean @default(true)
  reminder24h        Boolean @default(true)
  reminder1h         Boolean @default(false)
  reviewRequestEnabled Boolean @default(true)
  rebookingReminderDays Int   @default(30)

  loyaltyEnabled          Boolean @default(false)
  loyaltyPointsPerBooking Int     @default(10)
  loyaltyPointsPerPurchase Int    @default(1)
  loyaltyPointValue       Int     @default(100)

  socialInstagram String?
  socialFacebook  String?
  socialTiktok    String?
  socialWhatsapp  String?

  updatedAt DateTime @updatedAt
}

model BusinessCustomization {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  primaryColor   String @default("#0D1B2A")
  secondaryColor String @default("#CFE3DF")
  accentColor    String @default("#6FA89E")
  fontFamily     String @default("Inter")
  borderRadius   String @default("0.75rem")
  darkMode       Boolean @default(false)

  // ── Sistema de temas (Fase 10 / Auditoría) ──
  themeMode          String  @default("light")    // "light" | "dark" | "auto"
  densityPreset      String  @default("normal")   // "compact" | "normal" | "spacious"
  borderRadiusPreset String  @default("rounded")  // "sharp" | "rounded" | "pill"
  dashboardBgType    String  @default("gradient") // "solid" | "gradient" | "image"
  dashboardBgValue   String?
  // Colores en HSL para inyección directa en CSS variables (calculados desde los hex)
  primaryColorHsl    String  @default("211 53% 11%")
  accentColorHsl     String  @default("170 25% 55%")
  secondaryColorHsl  String  @default("169 26% 85%")

  heroTitle       String?
  heroSubtitle    String?
  heroImageUrl    String?
  heroVideoUrl    String?
  galleryUrls     String[]
  metaTitle       String?
  metaDescription String?

  // Página pública premium (Fase 12)
  servicesLayout     String  @default("grid")   // "grid" | "list"
  showGallery        Boolean @default(true)
  showMap            Boolean @default(true)
  showSchedule       Boolean @default(true)
  showStaffBios      Boolean @default(true)
  showReviews        Boolean @default(true)
  showFaq            Boolean @default(true)
  cancellationPolicy String?
  faqs               Json    @default("[]")     // [{ question, answer }][]
  mapEmbed           String?                    // Google Maps embed URL
  customDomain       String?                    // dominio propio (Business+)

  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// STAFF Y HORARIOS
// ─────────────────────────────────────────────

model StaffMember {
  id         String  @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?   @relation(fields: [userId], references: [id])
  locationId String?
  location   BusinessLocation? @relation(fields: [locationId], references: [id])

  name        String
  email       String?
  phone       String?
  avatarUrl   String?
  bio         String?
  specialties String[] @default([])
  role        UserRole @default(STAFF)
  color       String   @default("#6d28d9")
  isActive    Boolean  @default(true)
  commissionRate Float? @default(0)
  commissionType String @default("PERCENT")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedules    StaffSchedule[]
  timeOff      StaffTimeOff[]
  services     StaffService[]
  appointments Appointment[]
  groupClasses GroupClass[]
  timeBlocks   TimeBlock[]
  soapNotes    SoapNote[]
  beforeAfterPhotos BeforeAfterPhoto[]

  @@index([businessId])
  @@index([userId])
}

model StaffSchedule {
  id          String      @id @default(cuid())
  staffId     String
  staff       StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  dayOfWeek   Int
  startTime   String
  endTime     String
  isAvailable Boolean @default(true)

  @@index([staffId])
}

model StaffTimeOff {
  id      String      @id @default(cuid())
  staffId String
  staff   StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  startDate DateTime
  endDate   DateTime
  reason    String?

  @@index([staffId])
}

model StaffService {
  staffId   String
  staff     StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  price     Float?

  @@id([staffId, serviceId])
}

// ─────────────────────────────────────────────
// SERVICIOS
// ─────────────────────────────────────────────

model ServiceCategory {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name     String
  color    String  @default("#6d28d9")
  order    Int     @default(0)
  isActive Boolean @default(true)

  services Service[]

  @@index([businessId])
}

model Service {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  categoryId String?
  category   ServiceCategory? @relation(fields: [categoryId], references: [id])

  name        String
  description String?
  imageUrl    String?
  duration    Int
  price       Float
  priceMax    Float?
  isOnline    Boolean @default(true)
  isActive    Boolean @default(true)
  order       Int     @default(0)
  color       String  @default("#6d28d9")
  requiresDeposit Boolean @default(false)
  depositAmount   Float?
  bufferMinutes   Int     @default(0)
  prepTime        Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff            StaffService[]
  appointmentItems AppointmentService[]
  addOns           ServiceAddOn[]
  groupClasses     GroupClass[]
  serviceForms     ServiceForm[]

  @@index([businessId])
  @@index([categoryId])
}

model ServiceAddOn {
  id        String  @id @default(cuid())
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  name     String
  price    Float
  duration Int     @default(0)
  isActive Boolean @default(true)

  @@index([serviceId])
}

// ─────────────────────────────────────────────
// CLIENTES DEL NEGOCIO
// ─────────────────────────────────────────────

model Client {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name      String
  email     String?
  phone     String?
  avatarUrl String?
  birthdate DateTime?
  gender    String?
  notes     String?
  tags      String[]
  isActive  Boolean   @default(true)

  allergies     String?
  preferences   String?
  referredBy    String?
  source        String?
  loyaltyPoints Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments     AppointmentClient[]
  payments         Payment[]
  giftCards        GiftCard[]   @relation("GiftCardRecipient")
  formResponses    FormResponse[]
  classEnrollments ClassEnrollment[]
  soapNotes        SoapNote[]
  beforeAfterPhotos BeforeAfterPhoto[]
  clientMemberships ClientMembership[]
  clientPackages   ClientPackage[]
  portalTokens     ClientPortalToken[]

  @@unique([businessId, email])
  @@index([businessId])
  @@index([phone])
}

// ─────────────────────────────────────────────
// CITAS / RESERVAS
// ─────────────────────────────────────────────

model Appointment {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  locationId String?
  location   BusinessLocation? @relation(fields: [locationId], references: [id])
  staffId    String?
  staff      StaffMember? @relation(fields: [staffId], references: [id])
  userId     String?
  user       User?    @relation("ClientAppointments", fields: [userId], references: [id])

  bookingCode String @unique @default(cuid())
  status      AppointmentStatus @default(PENDING)
  startTime   DateTime
  endTime     DateTime
  totalPrice  Float
  notes       String?
  internalNotes String?
  source      String  @default("ONLINE")
  confirmationSentAt DateTime?
  reminderSentAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients  AppointmentClient[]
  services AppointmentService[]
  payment  Payment?
  formResponses FormResponse[]
  soapNotes     SoapNote[]
  beforeAfterPhotos BeforeAfterPhoto[]
  review   Review?

  @@index([businessId])
  @@index([staffId])
  @@index([startTime])
  @@index([status])
}

model AppointmentClient {
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@id([appointmentId, clientId])
}

model AppointmentService {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id])

  serviceName   String
  price         Float
  duration      Int

  @@index([appointmentId])
}

// ─────────────────────────────────────────────
// PAGOS Y FACTURAS
// ─────────────────────────────────────────────

model Payment {
  id            String   @id @default(cuid())
  businessId    String
  appointmentId String?  @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id])

  amount          Float
  tip             Float  @default(0)
  discount        Float  @default(0)
  taxAmount       Float  @default(0)
  total           Float
  currency        String @default("CLP")
  method          PaymentMethod @default(CASH)
  status          PaymentStatus @default(PENDING)
  flowOrderId     String?
  flowToken       String?
  giftCardId      String?
  notes           String?
  refundedAmount  Float?
  refundReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice Invoice?

  @@index([businessId])
  @@index([clientId])
}

model Invoice {
  id        String  @id @default(cuid())
  paymentId String  @unique
  payment   Payment @relation(fields: [paymentId], references: [id])

  invoiceNumber String @unique
  issueDate     DateTime @default(now())
  dueDate       DateTime?
  pdfUrl        String?
  emailSentAt   DateTime?
  notes         String?

  @@index([paymentId])
}

// ─────────────────────────────────────────────
// INVENTARIO Y PRODUCTOS
// ─────────────────────────────────────────────

model ProductCategory {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name     String
  order    Int     @default(0)
  isActive Boolean @default(true)

  products Product[]

  @@index([businessId])
}

model Product {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id])

  name        String
  description String?
  sku         String?
  barcode     String?
  imageUrl    String?
  costPrice   Float   @default(0)
  salePrice   Float
  stock       Int     @default(0)
  minStock    Int     @default(5)
  unit        String  @default("un")
  isActive    Boolean @default(true)
  isSellable  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements InventoryMovement[]

  @@index([businessId])
  @@index([sku])
}

model InventoryMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  type      InventoryMovementType
  quantity  Int
  unitCost  Float?
  reference String?
  notes     String?
  createdAt DateTime @default(now())

  @@index([productId])
}

// ─────────────────────────────────────────────
// GIFT CARDS
// ─────────────────────────────────────────────

model GiftCard {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  recipientId String?
  recipient   Client?  @relation("GiftCardRecipient", fields: [recipientId], references: [id])

  code          String @unique
  initialValue  Float
  currentValue  Float
  status        GiftCardStatus @default(ACTIVE)
  expiresAt     DateTime?
  purchaserName String?
  purchaserEmail String?
  message       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([code])
}

model Coupon {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  code        String
  description String?
  type        CouponType
  value       Float
  minAmount   Float?
  maxUses     Int?
  usedCount   Int      @default(0)
  isActive    Boolean  @default(true)
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, code])
  @@index([businessId])
}

// ─────────────────────────────────────────────
// MARKETING Y COMUNICACIONES
// ─────────────────────────────────────────────

model Campaign {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  subject     String?
  content     String
  channel     CampaignChannel
  status      CampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  sentCount   Int @default(0)
  openCount   Int @default(0)
  clickCount  Int @default(0)
  segment     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

model Notification {
  id         String   @id @default(cuid())
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])

  type    NotificationType
  event   NotificationEvent
  to      String
  subject String?
  body    String
  status  String  @default("SENT")
  error   String?

  sentAt    DateTime @default(now())

  @@index([businessId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// FORMULARIOS
// ─────────────────────────────────────────────

model Form {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  description String?
  type        FormType @default(PRE_APPOINTMENT)
  isRequired  Boolean  @default(false)
  isActive    Boolean  @default(true)
  isConsent   Boolean  @default(false)
  sendBefore  Int      @default(24)
  sendVia     String[] @default(["EMAIL"])

  fields       FormField[]
  responses    FormResponse[]
  serviceForms ServiceForm[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

model FormField {
  id     String @id @default(cuid())
  formId String
  form   Form   @relation(fields: [formId], references: [id], onDelete: Cascade)

  label        String
  type         FormFieldType
  placeholder  String?
  options      String[]
  isRequired   Boolean  @default(false)
  order        Int      @default(0)
  min          Int?
  max          Int?
  helpText     String?
  defaultValue String?

  @@index([formId])
}

model FormResponse {
  id            String      @id @default(cuid())
  formId        String
  form          Form        @relation(fields: [formId], references: [id])
  clientId      String?
  client        Client?     @relation(fields: [clientId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  data        Json
  signedAt    DateTime?
  signature   String?
  token       String?   @unique
  expiresAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())

  @@index([formId])
  @@index([clientId])
  @@index([token])
}

model ServiceForm {
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  formId    String
  form      Form    @relation(fields: [formId], references: [id], onDelete: Cascade)
  order     Int     @default(0)

  @@id([serviceId, formId])
  @@index([formId])
}

// ─────────────────────────────────────────────
// RESEÑAS
// ─────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  appointmentId String?     @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  clientName  String
  clientEmail String?
  rating      Int
  comment     String?
  isVerified  Boolean @default(false)
  isPublic    Boolean @default(true)
  reply       String?
  repliedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([businessId])
}

// ─────────────────────────────────────────────
// AGENDA AVANZADA — Fase 8
// ─────────────────────────────────────────────

model GroupClass {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffId    String?
  staff      StaffMember? @relation(fields: [staffId], references: [id])
  serviceId  String?
  service    Service?  @relation(fields: [serviceId], references: [id])

  name        String
  description String?
  color       String  @default("#6FA89E")
  maxCapacity Int
  price       Float   @default(0)
  requiresDeposit Boolean @default(false)
  depositAmount   Float?

  startTime DateTime
  endTime   DateTime
  isRecurring Boolean @default(false)
  recurringRule String? // JSON: { frequency: "WEEKLY", days: [1,3,5] }

  isActive  Boolean @default(true)
  isPublic  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments ClassEnrollment[]

  @@index([businessId])
  @@index([startTime])
}

model ClassEnrollment {
  id         String     @id @default(cuid())
  classId    String
  class      GroupClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  clientId   String?
  client     Client?    @relation(fields: [clientId], references: [id])

  clientName  String
  clientEmail String?
  clientPhone String?
  status      EnrollmentStatus @default(ENROLLED)
  checkedInAt DateTime?
  paymentId   String?

  createdAt DateTime @default(now())

  @@index([classId])
}

model Waitlist {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceId  String?
  staffId    String?
  classId    String?

  clientName  String
  clientEmail String?
  clientPhone String?
  preferredDate DateTime?
  notes       String?
  status      WaitlistStatus @default(WAITING)
  notifiedAt  DateTime?

  createdAt DateTime @default(now())

  @@index([businessId])
}

model TimeBlock {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffId    String?
  staff      StaffMember? @relation(fields: [staffId], references: [id])

  title     String
  startTime DateTime
  endTime   DateTime
  color     String  @default("#94a3b8")
  reason    String? // vacaciones, reunión, descanso, limpieza, etc.

  createdAt DateTime @default(now())

  @@index([businessId])
  @@index([startTime])
}

// ─────────────────────────────────────────────
// SOAP NOTES Y FICHAS CLÍNICAS — Fase 13
// ─────────────────────────────────────────────

model SoapNote {
  id            String       @id @default(cuid())
  businessId    String
  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  staffId       String?
  staff         StaffMember? @relation(fields: [staffId], references: [id])
  templateId    String?

  subjective  String  @db.Text
  objective   String  @db.Text
  assessment  String  @db.Text
  plan        String  @db.Text
  extraFields Json?   @default("{}")
  isPrivate   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([clientId])
  @@index([appointmentId])
}

model SoapTemplate {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  serviceId   String?
  extraFields Json    @default("[]")
  isDefault   Boolean @default(false)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

// ─────────────────────────────────────────────
// GALERÍA BEFORE/AFTER — Fase 13
// ─────────────────────────────────────────────

model BeforeAfterPhoto {
  id            String       @id @default(cuid())
  businessId    String
  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id])
  staffId       String?
  staff         StaffMember? @relation(fields: [staffId], references: [id])

  beforeKey      String
  afterKey       String
  beforeUrl      String
  afterUrl       String
  caption        String?
  serviceTag     String?
  isPublic       Boolean   @default(false)
  hasConsent     Boolean   @default(false)
  consentAt      DateTime?
  shareToken     String?   @unique
  shareExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([clientId])
  @@index([staffId])
}

enum EnrollmentStatus {
  ENROLLED
  WAITLISTED
  CANCELED
  ATTENDED
  NO_SHOW
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  CONFIRMED
  EXPIRED
}

// ─────────────────────────────────────────────
// SUSCRIPCIONES A FRANDORA (Planes)
// ─────────────────────────────────────────────

model Plan {
  id   String   @id @default(cuid())
  tier PlanTier @unique

  name            String
  description     String?
  monthlyPrice    Float
  annualPrice     Float
  staffLimit      Int?
  locationLimit   Int?
  appointmentLimit Int?
  smsIncluded     Int     @default(0)
  features        String[]
  rebillMonthlyPriceId String?
  rebillAnnualPriceId  String?
  isActive        Boolean @default(true)

  subscriptions Subscription[]
}

model Subscription {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  planId     String
  plan       Plan     @relation(fields: [planId], references: [id])

  status            SubscriptionStatus @default(TRIALING)
  rebillCustomerId  String?
  rebillSubId       String?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  cancelAtPeriodEnd  Boolean @default(false)
  isAnnual           Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([rebillSubId])
}

// ─────────────────────────────────────────────
// AUDIT LOG — Fase 11
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  businessId String?
  userId     String?

  action     String   // CREATE_APPOINTMENT, CANCEL_APPOINTMENT, UPDATE_SETTINGS, etc.
  resource   String   // appointment, client, payment, staff, settings
  resourceId String?
  metadata   Json?    // datos adicionales del evento
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([businessId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// FASE 14 — MEMBRESÍAS, PAQUETES Y PORTAL
// ─────────────────────────────────────────────

enum MembershipBillingCycle {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum ClientMembershipStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum ClientPackageStatus {
  ACTIVE
  DEPLETED
  EXPIRED
  CANCELLED
}

model Membership {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name            String
  description     String?
  price           Float
  billingCycle    MembershipBillingCycle @default(MONTHLY)
  sessionsPerCycle Int?
  discountPercent Float   @default(0)
  color           String  @default("#6FA89E")
  isActive        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientMemberships ClientMembership[]

  @@index([businessId])
}

model ClientMembership {
  id           String   @id @default(cuid())
  businessId   String
  business     Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clientId     String
  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  membershipId String
  membership   Membership @relation(fields: [membershipId], references: [id])

  status          ClientMembershipStatus @default(ACTIVE)
  startDate       DateTime
  endDate         DateTime
  nextBillingDate DateTime?
  sessionsUsed    Int       @default(0)
  flowOrderId     String?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([clientId])
  @@index([membershipId])
  @@index([status])
}

model SessionPackage {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  description String?
  sessions    Int
  price       Float
  validDays   Int     @default(0)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientPackages ClientPackage[]

  @@index([businessId])
}

model ClientPackage {
  id        String   @id @default(cuid())
  businessId String
  business   Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clientId   String
  client     Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  packageId  String
  package    SessionPackage @relation(fields: [packageId], references: [id])

  status         ClientPackageStatus @default(ACTIVE)
  sessionsTotal  Int
  sessionsUsed   Int      @default(0)
  purchaseDate   DateTime @default(now())
  expiresAt      DateTime?
  flowOrderId    String?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([clientId])
  @@index([status])
}

model ClientPortalToken {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  token        String   @unique
  expiresAt    DateTime
  lastAccessAt DateTime?

  createdAt DateTime @default(now())

  @@index([token])
  @@index([clientId])
  @@index([businessId])
}

// ─────────────────────────────────────────────
// FASE 15 — SUPER ADMIN
// ─────────────────────────────────────────────

model BusinessNote {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  authorId   String
  content    String
  isPinned   Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// FASE 15.3 — FEATURE FLAGS
// ─────────────────────────────────────────────

enum FeatureFlagScope {
  ALL
  PLAN
  BUSINESS
}

model FeatureFlag {
  id            String           @id @default(cuid())
  name          String           @unique
  description   String?
  scope         FeatureFlagScope @default(ALL)
  enabledForAll Boolean          @default(false)
  rolloutPercent Int             @default(0)
  enabledPlans  PlanTier[]       @default([])
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  overrides BusinessFeatureFlag[]

  @@index([name])
}

model BusinessFeatureFlag {
  businessId   String
  business     Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  featureName  String
  flag         FeatureFlag @relation(fields: [featureName], references: [name], onDelete: Cascade)
  enabled      Boolean     @default(false)
  overriddenBy String?
  overriddenAt DateTime    @default(now())

  @@id([businessId, featureName])
  @@index([businessId])
}

// ─────────────────────────────────────────────
// FASE 15.4 — COMUNICACIONES GLOBALES
// ─────────────────────────────────────────────

enum AnnouncementType {
  BANNER
  CHANGELOG
  MAINTENANCE
  PROMOTION
}

model Announcement {
  id          String           @id @default(cuid())
  title       String
  content     String
  type        AnnouncementType @default(BANNER)
  isActive    Boolean          @default(true)
  targetPlans PlanTier[]       @default([])
  startsAt    DateTime?
  endsAt      DateTime?
  ctaLabel    String?
  ctaUrl      String?
  authorId    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([isActive])
  @@index([type])
}

model BroadcastEmail {
  id          String         @id @default(cuid())
  subject     String
  content     String
  targetPlans PlanTier[]     @default([])
  status      CampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  sentCount   Int            @default(0)
  authorId    String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status])
}

// ─────────────────────────────────────────────
// FASE 15.5 — SOPORTE INTEGRADO
// ─────────────────────────────────────────────

enum TicketStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id          String         @id @default(cuid())
  businessId  String
  business    Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title       String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  messages TicketMessage[]

  @@index([businessId])
  @@index([status])
  @@index([priority])
}

model TicketMessage {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  content    String
  authorId   String
  authorName String
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())

  @@index([ticketId])
}
